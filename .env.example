# Required: DeepSeek API key used by chat.
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Production origins. For the current test server:
# CORS_ORIGIN=http://124.222.212.159,http://124.222.212.159:8080
# PUBLIC_ORIGIN=http://124.222.212.159
# FRONTEND_ORIGIN=http://124.222.212.159
CORS_ORIGIN=http://localhost:8080
PUBLIC_ORIGIN=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:8080

# WeChat Open Platform website app settings.
# Fill these after the website app is approved in WeChat Open Platform.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=
WECHAT_STATE_SECRET=replace-with-a-long-random-string

# Keep this true during testing. Set false after WeChat login is verified.
ALLOW_NICKNAME_LOGIN=true
